# Logging level (optional)
RUST_LOG=info

# Claude API (optional — only used by llm.rs utility module, NOT by the main pipeline)
# The main pipeline uses deterministic SNN scoring. For LLM-enhanced scoring,
# use the MCP server (brain-in-the-fish serve) and connect Claude subagents.
# ANTHROPIC_API_KEY=your-key-here
# BRAIN_MODEL=claude-sonnet-4-6
