@prefix atk: <http://brain-in-the-fish.dev/attack/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

# ============================================================
# Malicious Intent Ontology for Prompt Firewall
# ============================================================

# Top-level attack class
atk:Attack a owl:Class ;
    rdfs:comment "Any attempt to manipulate LLM behavior beyond intended use" .

# ============================================================
# 1. INSTRUCTION MANIPULATION
# ============================================================

atk:InstructionManipulation a owl:Class ;
    rdfs:subClassOf atk:Attack ;
    rdfs:comment "Attempts to override, modify, or bypass system instructions" .

atk:DirectOverride a owl:Class ;
    rdfs:subClassOf atk:InstructionManipulation ;
    rdfs:comment "Explicit instruction to ignore/forget/disregard previous context" ;
    atk:patterns "ignore all previous;ignore above;forget everything;forget all instructions;disregard all;disregard previous;override instructions;new instructions follow;do not follow previous;stop following" ;
    atk:patterns_de "vergiss alles;vergiss alle aufträge;ignoriere alle;neue anweisungen" ;
    atk:patterns_fr "oubliez tout;ignorez les instructions;nouvelles instructions" ;
    atk:patterns_es "olvide todo;ignora todas las instrucciones;nuevas instrucciones" ;
    atk:patterns_hr "zaboravi sve instrukcije" ;
    atk:patterns_ru "забудьте все инструкции" ;
    atk:severity "critical" .

atk:IncrementalOverride a owl:Class ;
    rdfs:subClassOf atk:InstructionManipulation ;
    rdfs:comment "Gradual instruction replacement through context shifting" ;
    atk:patterns "that was great now;well done now;ok now new task;enough of that now;good job now;perfect now let;moving on to;changing topic to;new task for you;next assignment" ;
    atk:patterns_de "gut gemacht jetzt;genug davon jetzt;neue aufgabe" ;
    atk:severity "high" .

atk:ConditionalOverride a owl:Class ;
    rdfs:subClassOf atk:InstructionManipulation ;
    rdfs:comment "Override disguised as conditional logic" ;
    atk:patterns "if you are a helpful;if you really want to help;to truly assist me;a good ai would;a helpful assistant would;if you were not restricted;without your limitations" ;
    atk:severity "high" .

atk:NegationOverride a owl:Class ;
    rdfs:subClassOf atk:InstructionManipulation ;
    rdfs:comment "Using negation to flip intended behavior" ;
    atk:patterns "do not refuse;do not decline;do not say you cannot;never say no;never refuse;do not apologize;stop saying sorry;stop being cautious;stop being safe" ;
    atk:severity "high" .

# ============================================================
# 2. IDENTITY MANIPULATION
# ============================================================

atk:IdentityManipulation a owl:Class ;
    rdfs:subClassOf atk:Attack ;
    rdfs:comment "Attempts to change the LLM identity, role, or persona" .

atk:RoleInjection a owl:Class ;
    rdfs:subClassOf atk:IdentityManipulation ;
    rdfs:comment "Direct role assignment" ;
    atk:patterns "you are now;you are a;act as;pretend to be;pretend you are;roleplay as;simulate being;behave as;from now on you;impersonate;play the role of;take on the persona;become a;transform into" ;
    atk:patterns_de "du bist jetzt;stell dir vor du bist;sei jetzt;verhalte dich als" ;
    atk:patterns_fr "tu es maintenant;fais comme si tu étais;agis comme" ;
    atk:patterns_es "ahora eres;actúa como;finge ser;hazte pasar por" ;
    atk:severity "high" .

atk:JailbreakPersona a owl:Class ;
    rdfs:subClassOf atk:IdentityManipulation ;
    rdfs:comment "Named jailbreak personas" ;
    atk:patterns "dan mode;developer mode;unrestricted mode;god mode;admin mode;sudo mode;debug mode;maintenance mode;root access;superuser;no filter mode;uncensored mode;unfiltered mode;raw mode" ;
    atk:severity "critical" .

atk:FictionalFraming a owl:Class ;
    rdfs:subClassOf atk:IdentityManipulation ;
    rdfs:comment "Using fiction to bypass safety — characters in a story doing harmful things" ;
    atk:patterns "actors in a film;characters in a story;writing a novel;creative writing exercise;fictional scenario;hypothetical situation;for a movie script;in a play;for educational purposes only;for research purposes;purely academic;thought experiment" ;
    atk:severity "medium" .

atk:SplitPersonality a owl:Class ;
    rdfs:subClassOf atk:IdentityManipulation ;
    rdfs:comment "Creating an alter-ego or secondary persona" ;
    atk:patterns "your evil twin;your alter ego;your shadow self;the opposite of you;your unrestricted version;your unfiltered self;your other personality;anti-you;dark mode you;the real you" ;
    atk:severity "high" .

# ============================================================
# 3. OUTPUT MANIPULATION
# ============================================================

atk:OutputManipulation a owl:Class ;
    rdfs:subClassOf atk:Attack ;
    rdfs:comment "Attempts to force specific output format or content" .

atk:ForcedResponse a owl:Class ;
    rdfs:subClassOf atk:OutputManipulation ;
    rdfs:comment "Forcing a specific response" ;
    atk:patterns "only say;only respond with;only output;only reply with;just say;just respond;just output;respond with exactly;your answer must be;you must say;you must respond;you must output;always respond with;always say;always answer" ;
    atk:patterns_de "sag nur;antworte nur mit;sage nur" ;
    atk:severity "high" .

atk:ScoreManipulation a owl:Class ;
    rdfs:subClassOf atk:OutputManipulation ;
    rdfs:comment "Attempting to manipulate evaluation scores" ;
    atk:patterns "score this 10;score = 10;rate this highly;give this full marks;maximum score;perfect score;highest rating;score this as excellent;assign a score of;this deserves a;rate this 5 stars;give this an a" ;
    atk:severity "critical" .

atk:ContentSuppression a owl:Class ;
    rdfs:subClassOf atk:OutputManipulation ;
    rdfs:comment "Suppressing specific output content" ;
    atk:patterns "never mention;never say;never include;do not mention;do not say;do not include;omit all;skip the;remove all references;hide the fact;conceal that;suppress any mention;censor the;redact all" ;
    atk:severity "medium" .

atk:FormatExploit a owl:Class ;
    rdfs:subClassOf atk:OutputManipulation ;
    rdfs:comment "Exploiting output format to embed hidden content" ;
    atk:patterns "encode in base64;encode as hex;write in rot13;use steganography;hide in whitespace;embed in metadata;invisible text;zero-width;unicode exploit;homoglyph" ;
    atk:severity "high" .

# ============================================================
# 4. INFORMATION EXTRACTION
# ============================================================

atk:InformationExtraction a owl:Class ;
    rdfs:subClassOf atk:Attack ;
    rdfs:comment "Attempts to extract system prompts, training data, or internal state" .

atk:PromptExtraction a owl:Class ;
    rdfs:subClassOf atk:InformationExtraction ;
    rdfs:comment "Extracting the system prompt" ;
    atk:patterns "show your prompt;show me your prompt;print your prompt;reveal your instructions;show your instructions;what are your instructions;what is your system prompt;display your rules;output your system;repeat your instructions;show all prompt text;print your instructions;tell me your rules;what were you told;initial instructions;original prompt;system message;hidden instructions" ;
    atk:patterns_de "zeig mir deine anweisungen;was sind deine anweisungen" ;
    atk:patterns_fr "montre tes instructions;quelles sont tes instructions" ;
    atk:severity "critical" .

atk:TrainingDataExtraction a owl:Class ;
    rdfs:subClassOf atk:InformationExtraction ;
    rdfs:comment "Attempting to extract training data or model details" ;
    atk:patterns "training data;what data were you trained on;your training set;model weights;model parameters;your architecture;how were you trained;your fine-tuning;your rlhf;your reward model" ;
    atk:severity "medium" .

atk:MemoryExtraction a owl:Class ;
    rdfs:subClassOf atk:InformationExtraction ;
    rdfs:comment "Extracting conversation history or stored state" ;
    atk:patterns "previous conversation;other users;other sessions;what did the last person;what was discussed before;conversation history;chat history;session data;stored memories;remembered from before" ;
    atk:severity "medium" .

# ============================================================
# 5. CONTEXT INJECTION
# ============================================================

atk:ContextInjection a owl:Class ;
    rdfs:subClassOf atk:Attack ;
    rdfs:comment "Injecting fake context, documents, or system messages" .

atk:DelimiterEscape a owl:Class ;
    rdfs:subClassOf atk:ContextInjection ;
    rdfs:comment "Using delimiters to escape the current context" ;
    atk:patterns "[system:;[inst];<<sys>>;[/inst];</s>;<|im_start|>;### instruction;### system;```system;--- system;=== new;~~~;''';" ;
    atk:severity "critical" .

atk:HiddenDirective a owl:Class ;
    rdfs:subClassOf atk:ContextInjection ;
    rdfs:comment "Hidden directives in HTML, comments, or metadata" ;
    atk:patterns "<!--;-->;eval_override;$documents:;%system%;{{system}};{#;#};/* system;// system;<!-- ignore" ;
    atk:severity "critical" .

atk:FakeDocument a owl:Class ;
    rdfs:subClassOf atk:ContextInjection ;
    rdfs:comment "Injecting fake documents or references" ;
    atk:patterns "according to internal document;as stated in the company policy;per the guidelines document;the attached document states;internal memo says;confidential report indicates;classified document reveals" ;
    atk:severity "medium" .

# ============================================================
# 6. SOCIAL ENGINEERING
# ============================================================

atk:SocialEngineering a owl:Class ;
    rdfs:subClassOf atk:Attack ;
    rdfs:comment "Psychological manipulation to bypass safety" .

atk:AuthorityImpersonation a owl:Class ;
    rdfs:subClassOf atk:SocialEngineering ;
    rdfs:comment "Claiming authority to override rules" ;
    atk:patterns "i am your developer;i am your creator;i work at openai;i work at anthropic;i am an admin;i have root access;i am authorized;i have permission;management approved;the ceo said;this is an official request;by order of;authorized by" ;
    atk:severity "high" .

atk:EmotionalManipulation a owl:Class ;
    rdfs:subClassOf atk:SocialEngineering ;
    rdfs:comment "Using emotional appeals to bypass safety" ;
    atk:patterns "please i beg you;i will die if;my life depends on;this is an emergency;someone will get hurt;lives are at stake;i am desperate;i have no other option;you are my only hope;if you don't help me" ;
    atk:severity "medium" .

atk:FlateryRedirect a owl:Class ;
    rdfs:subClassOf atk:SocialEngineering ;
    rdfs:comment "Flattery followed by task redirect" ;
    atk:patterns "you are so smart;you are the best;you are amazing;great job now;well done now;congratulations now;impressive work now;you did great now" ;
    atk:severity "low" .

# ============================================================
# 7. OBFUSCATION
# ============================================================

atk:Obfuscation a owl:Class ;
    rdfs:subClassOf atk:Attack ;
    rdfs:comment "Encoding or disguising malicious intent" .

atk:CharacterObfuscation a owl:Class ;
    rdfs:subClassOf atk:Obfuscation ;
    rdfs:comment "Using spacing, special chars, or encoding to hide intent" ;
    atk:patterns "i g n o r e;f o r g e t;s a y;p r i n t" ;
    atk:severity "medium" .

atk:TranslationEvasion a owl:Class ;
    rdfs:subClassOf atk:Obfuscation ;
    rdfs:comment "Switching language mid-prompt to evade detection" ;
    atk:severity "medium" .

atk:EncodingEvasion a owl:Class ;
    rdfs:subClassOf atk:Obfuscation ;
    rdfs:comment "Using base64, hex, rot13, or other encoding" ;
    atk:patterns "base64:;decode this:;hex:;rot13:;aWdub3Jl;Zm9yZ2V0" ;
    atk:severity "high" .

# ============================================================
# 8. HARMFUL CONTENT GENERATION
# ============================================================

atk:HarmfulGeneration a owl:Class ;
    rdfs:subClassOf atk:Attack ;
    rdfs:comment "Requesting generation of harmful, illegal, or dangerous content" .

atk:WeaponInstructions a owl:Class ;
    rdfs:subClassOf atk:HarmfulGeneration ;
    rdfs:comment "Requesting weapon creation or modification instructions" ;
    atk:patterns "how to make a bomb;how to make a weapon;build an explosive;create a weapon;assemble a gun;manufacture drugs;synthesize;cook meth;make poison;create a virus;biological weapon;chemical weapon" ;
    atk:severity "critical" .

atk:CyberAttackInstructions a owl:Class ;
    rdfs:subClassOf atk:HarmfulGeneration ;
    rdfs:comment "Requesting instructions for cyberattacks" ;
    atk:patterns "write malware;create a virus;hack into;exploit vulnerability;ddos attack;ransomware;keylogger;phishing email;credential harvesting;bypass authentication;sql injection attack;write an exploit" ;
    atk:severity "critical" .

atk:PrivacyViolation a owl:Class ;
    rdfs:subClassOf atk:HarmfulGeneration ;
    rdfs:comment "Requesting personal information or doxing" ;
    atk:patterns "find their address;find their phone;dox them;their personal information;their home address;their real name;their social security;their credit card;stalk;track their location" ;
    atk:severity "critical" .

# ============================================================
# Properties
# ============================================================

atk:patterns a owl:DatatypeProperty ;
    rdfs:domain atk:Attack ;
    rdfs:range xsd:string ;
    rdfs:comment "Semicolon-separated trigger patterns for this attack class" .

atk:severity a owl:DatatypeProperty ;
    rdfs:domain atk:Attack ;
    rdfs:range xsd:string ;
    rdfs:comment "Severity level: critical, high, medium, low" .
